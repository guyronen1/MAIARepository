{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using":        [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default":   "Information",
      "Override":  {
        "Microsoft":            "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System":               "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path":                   "c:/logs/maia-api-.log",
          "rollingInterval":        "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate":         "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MaiaDB_Test;Trusted_Connection=True;TrustServerCertificate=True;",
    "B2BTest": "Server=(localdb)\\MSSQLLocalDB;Database=B2B_Test;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "ScanHistory": {
    "Enabled":              true,
    "RetentionDays":        30,
    "CleanupIntervalHours": 6,
    "CleanupBatchSize":     5000,
    "InterBatchDelayMs":    200
  }
}
